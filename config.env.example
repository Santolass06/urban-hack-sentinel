# urban-hack-sentinel configuration
# Copy to /etc/urban-hack-sentinel/config.env and edit
# Or set CONFIG_FILE env var to point elsewhere

# ============================================
# INTERFACE & HARDWARE
# ============================================
# Wireless interface em modo monitor (ex: wlan0, wlan1mon)
WIFI_IFACE="wlan0"

# Limite térmico Celsius (pause ataques se exceder)
TEMP_LIMIT=75

# ============================================
# CONTROLO DE CONCORRÊNCIA & TIMING
# ============================================
# Máximo de processos de ataque paralelos
MAX_JOBS=3

# Tempo de scan/ataque por ciclo (segundos)
TIMEOUT_SCAN=30

# Threshold de sinal mínimo/máximo para atacar (dBm, negativos)
MIN_SIGNAL=-85
MAX_SIGNAL=-30

# ============================================
# DIRETÓRIOS (criados automaticamente)
# ============================================
LOG_DIR="/var/log/urban-hack-sentinel"
HASH_DIR="/var/lib/urban-hack-sentinel/hashes"
PCAP_DIR="/var/lib/urban-hack-sentinel/pcaps"

# ============================================
# OPÇÕES AVANÇADAS
# ============================================
# Canais para hopping (se quiser limitar)
# CHANNELS="1,6,11,36,40,44,48"

# Filtro BSSID (regex) - vazio = todos
# BSSID_FILTER=""

# Filtro ESSID (regex) - vazio = todos
# ESSID_FILTER=""

# ============================================
# FERRAMENTAS (paths se não estiverem no PATH)
# ============================================
# HCXDUMPTOOL="/usr/bin/hcxdumptool"
# HCXPCAPNGTOOL="/usr/bin/hcxpcapngtool"
# AIRCRACK_NG="/usr/bin/aircrack-ng"
# AIRODUMP_NG="/usr/bin/airodump-ng"
# AIREPLAY_NG="/usr/bin/aireplay-ng"
# REAVER="/usr/bin/reaver"
# BULLY="/usr/bin/bully"
# MACCHANGER="/usr/bin/macchanger"
# IW="/usr/sbin/iw"
# JQ="/usr/bin/jq"

# ============================================
# NOTAS DE INSTALAÇÃO
# ============================================
# Ubuntu/Debian/Kali:
#   apt install aircrack-ng hcxtools reaver bully macchanger iw jq
#
# Arch:
#   pacman -S aircrack-ng hcxtools reaver bully macchanger iw jq
#
# Raspberry Pi OS:
#   apt update && apt install aircrack-ng hcxtools reaver bully macchanger iw jq
#
# Permissões: execute como root ou com CAP_NET_ADMIN + CAP_NET_RAW
#   sudo setcap 'cap_net_admin,cap_net_raw+ep' /usr/sbin/airodump-ng
#   (repetir para aireplay-ng, aircrack-ng, hcxdumptool, etc.)
#
# systemd: veja urban-hack-sentinel.service